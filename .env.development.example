# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Database Configuration (Neon Local proxy inside Docker Compose)
DATABASE_URL=postgres://neon:npg@db:5432/neondb

# Neon Local Settings
NEON_LOCAL=true
NEON_LOCAL_HOST=db

# Neon API (required by the neon_local container)
# Get your API key from: https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=
# Found under Project Settings → General in the Neon console
NEON_PROJECT_ID=
# The branch ID to create ephemeral branches from (usually your main branch)
PARENT_BRANCH_ID=

# Arcjet
ARCJET_KEY=
